{
  "name": "kurumi-mail-backend",
  "version": "2.1.0",
  "description": "KurumiMail — Temporary email backend with built-in SMTP + React frontend",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev":          "node --watch src/server.js",
    "start":        "node src/server.js",
    "build:fe":     "cd ../frontend && npm install && npm run build",
    "start:prod":   "npm run build:fe && NODE_ENV=production node src/server.js",
    "start:server": "NODE_ENV=production node src/server.js"
  },
  "dependencies": {
    "compression":       "^1.8.1",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.19.2",
    "express-rate-limit":"^7.3.1",
    "helmet":            "^8.1.0",
    "mailparser":        "^3.7.1",
    "nodemailer":        "^6.9.13",
    "smtp-server":       "^3.13.4",
    "uuid":              "^10.0.0"
  }
}
